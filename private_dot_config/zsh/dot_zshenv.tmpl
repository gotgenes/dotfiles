export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

export EDITOR="nvim"

{{- if eq .chezmoi.os "darwin" }}
eval $(/opt/homebrew/bin/brew shellenv)
{{- else }}
eval $(/home/linuxbrew/.linuxbrew/bin/brew shellenv)
{{- end }}

export GOPATH="$HOME/development/go"

if (( $+commands[dotnet]  )); then
    export DOTNET_ROOT="$HOMEBREW_PREFIX/opt/dotnet/libexec"
fi

export PTPYTHON_CONFIG_HOME="$XDG_CONFIG_HOME/ptpython"

source "$ZDOTDIR/paths.zsh"

# Mise: shims for tool resolution in all shell contexts (including non-interactive
# `zsh -c` from OpenCode's bash tool), hook-env for per-directory env vars.
# Full `mise activate zsh` (with prompt hooks) is deferred to .zshrc.
if (( $+commands[mise] )); then
    eval "$(mise activate zsh --shims)"
    eval "$(mise hook-env -s zsh)"
fi
