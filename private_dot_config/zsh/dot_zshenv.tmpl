export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

export EDITOR="nvim"

{{- if eq .chezmoi.os "darwin" }}
eval $(/opt/homebrew/bin/brew shellenv)
{{- else }}
eval $(/home/linuxbrew/.linuxbrew/bin/brew shellenv)
{{- end }}

export GOPATH="$HOME/development/go"

if (( $+commands[dotnet]  )); then
    export DOTNET_ROOT="$HOMEBREW_PREFIX/opt/dotnet/libexec"
fi

export PTPYTHON_CONFIG_HOME="$XDG_CONFIG_HOME/ptpython"

source "$ZDOTDIR/paths.zsh"

# Activate mise for non-interactive shells only (e.g., OpenCode spawns `zsh -c`
# for each command, sourcing only .zshenv). Interactive shells get full
# activation in .zshrc instead, which avoids path_helper (.zprofile) demoting
# mise entries between the two files.
#
# We parse `mise env` output instead of eval'ing it directly for two reasons:
#   1. Env vars (e.g., AWS_PROFILE) are applied as defaults — inherited values
#      from inline overrides like `AWS_PROFILE=repone-admin <cmd>` take
#      precedence. `mise hook-env` can't do this; it unconditionally overwrites.
#   2. Only mise-specific PATH entries are prepended, preserving paths.zsh
#      ordering (e.g., ~/.local/bin before /opt/homebrew/bin). Both
#      `mise hook-env` and `mise activate --shims` prepend /opt/homebrew/bin,
#      which demotes ~/.local/bin wrapper scripts.
#
# hook-env's internal state vars (__MISE_DIFF, __MISE_SESSION) are unnecessary
# for one-shot non-interactive shells.

# Prepend only mise-managed PATH entries (installs/ dirs) to the existing PATH,
# plus the shims directory as a catch-all for tools not in the current
# directory's mise.toml.
_mise_prepend_paths() {
    local _mise_paths=() _raw _entry
    _raw="${1//\'/}"
    for _entry in "${(@s/:/)_raw}"; do
        [[ "$_entry" == */mise/* ]] && _mise_paths+=("$_entry")
    done
    local _shims_dir="${MISE_DATA_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/mise}/shims"
    [[ -d "$_shims_dir" ]] && _mise_paths+=("$_shims_dir")
    if (( ${#_mise_paths} )); then
        export PATH="${(j/:/)_mise_paths}:$PATH"
    fi
}

# Export a var only if it is not already set in the environment (i.e., not
# inherited from the parent process). This makes mise.toml values act as
# defaults that inline overrides can supersede.
_mise_export_default() {
    local _var="$1" _val="$2"
    if [[ -z "${(P)_var+x}" ]]; then
        eval "export ${_var}=${_val}"
    fi
}

if [[ ! -o interactive ]] && (( $+commands[mise] )); then
    local _line
    while IFS= read -r _line; do
        if [[ "$_line" == "export PATH="* ]]; then
            _mise_prepend_paths "${_line#export PATH=}"
        elif [[ "$_line" == "export "* ]]; then
            local _rest="${_line#export }"
            _mise_export_default "${_rest%%=*}" "${_rest#*=}"
        fi
    done < <(mise env -s zsh 2>/dev/null)
    unset _line
fi

unfunction _mise_prepend_paths _mise_export_default 2>/dev/null
