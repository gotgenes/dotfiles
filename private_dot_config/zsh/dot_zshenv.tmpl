export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

export EDITOR="nvim"

{{- if eq .chezmoi.os "darwin" }}
eval $(/opt/homebrew/bin/brew shellenv)
{{- else }}
eval $(/home/linuxbrew/.linuxbrew/bin/brew shellenv)
{{- end }}

export GOPATH="$HOME/development/go"

if (( $+commands[dotnet]  )); then
    export DOTNET_ROOT="$HOMEBREW_PREFIX/opt/dotnet/libexec"
fi

export PTPYTHON_CONFIG_HOME="$XDG_CONFIG_HOME/ptpython"

source "$ZDOTDIR/paths.zsh"

# Activate mise for non-interactive shells only (e.g., OpenCode spawns `zsh -c`
# for each command, sourcing only .zshenv). Interactive shells get full
# activation in .zshrc instead, which avoids path_helper (.zprofile) demoting
# mise entries between the two files.
#
# Use `mise env` instead of `mise hook-env` so that env vars from mise.toml
# (e.g., AWS_PROFILE) are applied as defaults — inherited values from inline
# overrides like `AWS_PROFILE=repone-admin <cmd>` take precedence.
# hook-env's extra state vars (__MISE_DIFF, __MISE_SESSION) are unnecessary
# for one-shot non-interactive shells.
if [[ ! -o interactive ]] && (( $+commands[mise] )); then
    # Extract mise tool install paths, shims, and env vars from `mise env`.
    # PATH: only prepend mise-specific entries (installs/ and shims/) to the
    # existing PATH so that paths.zsh ordering (e.g., ~/.local/bin before
    # homebrew) is preserved. We avoid `mise activate --shims` because it also
    # prepends /opt/homebrew/bin, which demotes ~/.local/bin wrapper scripts.
    # Env vars: apply as defaults only — inherited values take precedence.
    local _line _rest _var _val _mise_paths=()
    while IFS= read -r _line; do
        if [[ "$_line" == "export PATH="* ]]; then
            _rest="${_line#export PATH=}"
            _rest="${_rest//\'/}"
            for _val in "${(@s/:/)_rest}"; do
                [[ "$_val" == */mise/* ]] && _mise_paths+=("$_val")
            done
        elif [[ "$_line" == "export "* ]]; then
            _rest="${_line#export }"
            _var="${_rest%%=*}"
            _val="${_rest#*=}"
            if [[ -z "${(P)_var+x}" ]]; then
                eval "export ${_var}=${_val}"
            fi
        fi
    done < <(mise env -s zsh 2>/dev/null)
    # Always include the shims directory as a catch-all for tools not in the
    # current directory's mise.toml. mise env only outputs direct install paths.
    local _shims_dir="${XDG_DATA_HOME:-$HOME/.local/share}/mise/shims"
    [[ -d "$_shims_dir" ]] && _mise_paths+=("$_shims_dir")
    if (( ${#_mise_paths} )); then
        export PATH="${(j/:/)_mise_paths}:$PATH"
    fi
    unset _shims_dir
    unset _line _rest _var _val _mise_paths
fi
