export XDG_CONFIG_HOME="$HOME/.config"
export XDG_CACHE_HOME="$HOME/.cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_STATE_HOME="$HOME/.local/state"

export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

export EDITOR="nvim"

{{- if eq .chezmoi.os "darwin" }}
eval $(/opt/homebrew/bin/brew shellenv)
{{- else }}
eval $(/home/linuxbrew/.linuxbrew/bin/brew shellenv)
{{- end }}

export GOPATH="$HOME/development/go"

if (( $+commands[dotnet]  )); then
    export DOTNET_ROOT="$HOMEBREW_PREFIX/opt/dotnet/libexec"
fi

export PTPYTHON_CONFIG_HOME="$XDG_CONFIG_HOME/ptpython"

source "$ZDOTDIR/paths.zsh"

# Activate mise for non-interactive shells only (e.g., OpenCode's bash tool uses
# `zsh -c` which only sources .zshenv). Shims provide tool resolution; hook-env
# exports per-directory env vars and prepends direct tool paths.
# Interactive shells skip this — they get full activation in .zshrc instead,
# which avoids path_helper (.zprofile) demoting mise entries between the two files.
if [[ ! -o interactive ]] && (( $+commands[mise] )); then
    eval "$(mise activate zsh --shims)"
    eval "$(mise hook-env -s zsh)"
fi
