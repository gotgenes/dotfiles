{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@ex-machina/opencode-anthropic-auth"],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "mise.example.toml": "allow",
      "mise.*.toml": "deny",
      "mise/config.toml": "deny",
      ".config/mise.toml": "deny",
      ".config/mise/config.toml": "deny",
      ".config/mise/conf.d/*example.toml": "allow",
      ".config/mise/conf.d/*.toml": "deny"
    },
    "bash": {
      "*": "ask",
      "rg *": "allow",
      "fd *": "allow",
      "eza *": "allow",
      "bat *": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "cut *": "allow",
      "jq *": "allow",
      "dust *": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git status*": "allow",
      "git show*": "allow"
    }
  }
}
